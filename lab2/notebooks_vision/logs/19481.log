import torch
import gc
from unittest.mock import patch
from packaging import version
import transformers
from transformers import AutoModel, AutoTokenizer, BitsAndBytesConfig

# Limpiar memoria GPU antes de cargar
if torch.cuda.is_available():
    torch.cuda.empty_cache()
    gc.collect()

# ============================================================================
# WORKAROUND: Parche para modelos trust_remote_code con transformers >= 4.50
# El problema es que estos modelos no tienen el atributo `all_tied_weights_keys`
# que transformers espera durante la carga del modelo.
# ============================================================================

# Guardar método original
from transformers.modeling_utils import PreTrainedModel
_original_mark_tied = PreTrainedModel.mark_tied_weights_as_initialized

def _patched_mark_tied_weights_as_initialized(self, loading_info):
    """Versión parcheada que maneja modelos sin all_tied_weights_keys."""
    if not hasattr(self, 'all_tied_weights_keys'):
        self.all_tied_weights_keys = {}
    return _original_mark_tied(self, loading_info)

# Aplicar parche
PreTrainedModel.mark_tied_weights_as_initialized = _patched_mark_tied_weights_as_initialized

print(f"✓ Parche aplicado para transformers {transformers.__version__}")

# Función para cargar el modelo
def load_model_safe():
    """Carga el modelo con manejo de errores."""
    
    # Parche del linspace para el error del dispositivo meta
    original_linspace = torch.linspace
    
    def patched_linspace(*args, **kwargs):
        if 'device' in kwargs and str(kwargs['device']) == 'meta':
            kwargs['device'] = 'cpu'
        return original_linspace(*args, **kwargs)
    
    print(f"Cargando modelo {MODEL_NAME}...")
    
    with patch('torch.linspace', patched_linspace):
        model = AutoModel.from_pretrained(
            MODEL_NAME,
            torch_dtype=DTYPE,
            trust_remote_code=True,
            low_cpu_mem_usage=True,
        )
        # Mover a GPU manualmente
        model = model.to(DEVICE)
        print(f"✓ Modelo cargado en {DEVICE}")
    
    return model.eval()

# Cargar modelo
model = load_model_safe()

# Cargar tokenizer
tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME, trust_remote_code=True)

if tokenizer.pad_token is None:
    tokenizer.pad_token = tokenizer.eos_token
    tokenizer.pad_token_id = tokenizer.eos_token_id

# Verificar carga exitosa
print(f"\n✓ Modelo InternVL cargado correctamente")
print(f"  Dtype: {DTYPE}")
print(f"  Device: {next(model.parameters()).device}")
if torch.cuda.is_available():
    print(f"  Memoria GPU usada: {torch.cuda.memory_allocated() / 1e9:.2f} GB")
